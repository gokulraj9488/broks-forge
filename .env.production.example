# ===========================================================================
# Brok's Forge - Production environment (AWS EC2)
# ---------------------------------------------------------------------------
# Copy this to `.env` in the repo root ON THE EC2 HOST (never commit the real
# file) and fill in every value in "Required secrets":
#   cp .env.production.example .env
#   nano .env
#
# Consumed by docker-compose.prod.yml — NOT by the local-development
# docker-compose.yml, which has its own .env.example.
#
# GitHub Actions never sees this file — the deploy workflow only SSHes in and
# runs `docker compose ... up -d`, which reads THIS .env directly off the EC2
# disk. GitHub Secrets are for the SSH connection itself (EC2_HOST, EC2_USER,
# EC2_SSH_KEY) — see docs/DEPLOYMENT.md "GitHub Secrets" for the full list and
# why application secrets are deliberately NOT duplicated into GitHub Secrets.
# ===========================================================================

# ---------------------------------------------------------------------------
# REQUIRED SECRETS — the app fails fast at startup if any of these is missing.
# Generate fresh values per environment; never reuse a secret from local dev,
# staging, or a previous deployment.
# ---------------------------------------------------------------------------

# PostgreSQL. Pick a strong password — this is the platform's system of record.
POSTGRES_DB=broksforge
POSTGRES_USER=broksforge
POSTGRES_PASSWORD=

# Redis. A password is REQUIRED here (unlike local dev, where it may be blank) —
# Redis has no `ports:` mapping to the host, but requiring auth is cheap
# defense-in-depth against a container-escape or a future compose change that
# accidentally publishes the port.
#   openssl rand -base64 24
REDIS_PASSWORD=

# JWT signing secret (HS256). MUST be Base64, decoding to >= 32 bytes (256 bits).
# JwtService fails startup with a specific message naming this exact variable
# if it's missing, invalid Base64, or too short — see docs/DEPLOYMENT.md.
#   openssl rand -base64 48
JWT_SECRET=

# AES-256-GCM key used to encrypt agent/provider credentials at rest. MUST be
# Base64, decoding to EXACTLY 32 bytes. Rotating this invalidates every
# previously stored credential (see `key-version` in application.yml).
#   openssl rand -base64 32
ENCRYPTION_KEY=

# Allowed browser origin(s) for CORS — the deployed frontend's URL(s). Comma-
# separate multiple origins; no trailing slash on any of them.
CORS_ALLOWED_ORIGINS=https://broksforge.gokul.quest

# Public URL of the frontend, used to build links inside transactional e-mail.
APP_PUBLIC_URL=https://broksforge.gokul.quest

# ---------------------------------------------------------------------------
# OPTIONAL SETTINGS — sensible production defaults are baked into
# docker-compose.prod.yml already; only set these if you need to override them.
# ---------------------------------------------------------------------------

# JWT token lifetimes (milliseconds). Defaults: 15 min access / 30 day refresh.
# JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
# JWT_REFRESH_TOKEN_EXPIRATION_MS=2592000000
# JWT_ISSUER=broks-forge

# Evaluation engine tuning (defaults shown are what docker-compose.prod.yml
# already falls back to if these are unset).
# EVALUATION_MAX_ITEMS_PER_JOB=500

# AI Engineering Advisor heuristic thresholds.
# ADVISOR_PROMPT_MAX_CHARS=8000
# ADVISOR_PROMPT_MAX_VARIABLES=12
# ADVISOR_LATENCY_SPIKE_MS=12000
# ADVISOR_MIN_SAMPLES_FOR_COMPARISON=3
# ADVISOR_FAILURE_SAMPLE_SIZE=50

# Auth-endpoint rate limiting (Redis-backed; fails open if Redis is down).
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_LIMIT=20
# RATE_LIMIT_WINDOW_SECONDS=60

# E-mail (SMTP) — OPTIONAL. Leave SPRING_MAIL_HOST unset to run without SMTP;
# verification/reset/notification links are then written to the backend
# container's logs instead of being e-mailed (see docs/DEPLOYMENT.md
# "Is e-mail (SMTP) required?"). Set all four below together to enable it.
# SPRING_MAIL_HOST=smtp.your-provider.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=your-smtp-username-or-apikey
# SPRING_MAIL_PASSWORD=your-smtp-password-or-api-key
# BROKSFORGE_MAIL_FROM_ADDRESS=no-reply@broksforge.gokul.quest
# BROKSFORGE_MAIL_FROM_NAME=Brok's Forge

# Troubleshooting only — turns on Spring Boot's condition-evaluation report
# for one run. Leave unset/false in normal operation.
# DEBUG=false

# ---------------------------------------------------------------------------
# GENERATED / NOT SET HERE
# ---------------------------------------------------------------------------
# - TLS certificates: managed entirely by Certbot under ./nginx/certbot/ — not
#   an environment variable. See nginx/init-letsencrypt.sh.
# - SPRING_PROFILES_ACTIVE, SPRING_DATASOURCE_*, SPRING_DATA_REDIS_*: hardcoded
#   in docker-compose.prod.yml's `backend` service (they reference the other
#   variables above) — do not set them here, they'd be ignored/overridden.

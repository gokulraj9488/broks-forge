# ===========================================================================
# Brok's Forge - Environment Configuration
# ---------------------------------------------------------------------------
# Copy this file to `.env` and adjust the values for your environment.
#   cp .env.example .env
#
# NEVER commit the real `.env` file. Secrets are loaded from the environment
# only; nothing is hardcoded in the application.
# ===========================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=broksforge
POSTGRES_USER=broksforge
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_PORT=6379
# Leave empty for no password (local dev). Set a strong value in production.
REDIS_PASSWORD=

# ---------------------------------------------------------------------------
# Backend (Spring Boot)
# ---------------------------------------------------------------------------
BACKEND_PORT=8080
SPRING_PROFILES_ACTIVE=docker

# JWT signing secret. MUST be a Base64-encoded value of at least 256 bits
# (32 bytes) for the HS256 algorithm. Generate one with:
#   openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-base64-secret-at-least-32-bytes-long

# Access token lifetime in milliseconds (default 15 minutes)
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
# Refresh token lifetime in milliseconds (default 30 days)
JWT_REFRESH_TOKEN_EXPIRATION_MS=2592000000
# Token issuer claim
JWT_ISSUER=broks-forge

# AES-256-GCM key used to encrypt agent credentials at rest (Phase 2).
# MUST be a Base64-encoded 32-byte key. Generate one with:
#   openssl rand -base64 32
ENCRYPTION_KEY=replace-with-a-base64-encoded-32-byte-key

# Allow the platform to run health probes against private/loopback agent URLs.
# Keep false in production (SSRF protection); set true only for local testing.
AGENT_HEALTH_ALLOW_PRIVATE_TARGETS=false

# Phase 3 — evaluation/model invocation.
# Allow outbound model/evaluation calls to private/loopback agent URLs.
# Keep false in production (SSRF protection); set true only for local testing.
MODEL_ALLOW_PRIVATE_TARGETS=false
# Largest dataset a single synchronous evaluation job may run.
EVALUATION_MAX_ITEMS_PER_JOB=500

# Phase 4 — AI Engineering Advisor heuristic thresholds (all optional; sensible
# defaults shown). Tune sensitivity of the recommendation engines to your baselines.
ADVISOR_PROMPT_MAX_CHARS=8000
ADVISOR_PROMPT_MAX_VARIABLES=12
ADVISOR_LATENCY_SPIKE_MS=12000
ADVISOR_MIN_SAMPLES_FOR_COMPARISON=3
ADVISOR_FAILURE_SAMPLE_SIZE=50

# ---------------------------------------------------------------------------
# Auth rate limiting (Redis-backed; per client IP; fails open if Redis is down).
# Applies to register / login / verify-email / forgot-password / reset-password /
# resend-verification. Defaults shown.
# ---------------------------------------------------------------------------
BROKSFORGE_SECURITY_RATE_LIMIT_ENABLED=true
BROKSFORGE_SECURITY_RATE_LIMIT_LIMIT=20
BROKSFORGE_SECURITY_RATE_LIMIT_WINDOW_SECONDS=60

# ---------------------------------------------------------------------------
# Production e-mail (SMTP) — ONLY needed when SPRING_PROFILES_ACTIVE=prod.
# Local development uses the console LoggingEmailService and needs NONE of this
# (no SMTP, no account, no API keys). All values come from the environment;
# never commit real credentials. Spring maps SPRING_MAIL_* to spring.mail.*.
# ---------------------------------------------------------------------------
# SPRING_MAIL_HOST=smtp.your-provider.com
# SPRING_MAIL_PORT=587
# SPRING_MAIL_USERNAME=your-smtp-username-or-apikey
# SPRING_MAIL_PASSWORD=your-smtp-password
# BROKSFORGE_MAIL_FROM_ADDRESS=no-reply@yourdomain.com
# BROKSFORGE_MAIL_FROM_NAME=Brok's Forge
#
# Gmail SMTP example (STARTTLS on 587 is preconfigured in the prod profile).
# Use a Google "App Password" (Google Account -> Security -> 2-Step Verification
# -> App passwords) — NOT your normal account password:
#   SPRING_MAIL_HOST=smtp.gmail.com
#   SPRING_MAIL_PORT=587
#   SPRING_MAIL_USERNAME=your-address@gmail.com
#   SPRING_MAIL_PASSWORD=your-16-character-app-password
#   BROKSFORGE_MAIL_FROM_ADDRESS=your-address@gmail.com

# Comma-separated list of allowed CORS origins (the frontend URL)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Public base URL used when building links inside e-mails
APP_PUBLIC_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Frontend (Next.js)
# ---------------------------------------------------------------------------
FRONTEND_PORT=3000
# Base URL the browser uses to reach the backend API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
# Minutes of inactivity before the app signs the user out (0 disables).
NEXT_PUBLIC_IDLE_TIMEOUT_MINUTES=30
